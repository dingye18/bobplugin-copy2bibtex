{
  "identifier": "com.dingye18.bobplugin.copy2bibtex",
  "category": "translate",
  "version": "0.2.0",
  "name": "Copy2BibTeX",
  "summary": "将文献标题或 DOI 转换为 BibTeX",
  "author": "dingye18",
  "appcast": "https://raw.githubusercontent.com/dingye18/bobplugin-copy2bibtex/master/src/appcast.json",
  "homepage": "https://github.com/dingye18/bobplugin-copy2bibtex",
  "icon": "icon.png",
  "minBobVersion": "0.5.0",
  "options": [
    {
      "identifier": "llmProvider",
      "type": "menu",
      "title": "LLM 服务商",
      "defaultValue": "claude",
      "menuValues": [
        {
          "title": "Claude (Anthropic)",
          "value": "claude"
        },
        {
          "title": "OpenAI (GPT)",
          "value": "openai"
        },
        {
          "title": "Google (Gemini)",
          "value": "gemini"
        }
      ]
    },
    {
      "identifier": "apiKey",
      "type": "text",
      "title": "API Key",
      "defaultValue": "",
      "placeholder": "输入所选 LLM 服务商的 API Key（DOI 直接转换无需填写）"
    },
    {
      "identifier": "baseURL",
      "type": "text",
      "title": "自定义接口地址",
      "defaultValue": "",
      "placeholder": "留空使用默认地址（Claude: api.anthropic.com / OpenAI: api.openai.com / Gemini: generativelanguage.googleapis.com）"
    },
    {
      "identifier": "cache",
      "type": "menu",
      "title": "缓存",
      "defaultValue": "disable",
      "menuValues": [
        {
          "title": "开启",
          "value": "enable"
        },
        {
          "title": "关闭",
          "value": "disable"
        }
      ]
    }
  ]
}
